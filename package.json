{
  "name": "@responsivevoice/core",
  "version": "2.0.0",
  "description": "Modern, TypeScript-first text-to-speech (TTS) for the browser — native voices with automatic server fallback, streaming, and premium voices (Azure, OpenAI, Google Cloud, and more).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "attw": "attw --pack .",
    "api:check": "api-extractor run",
    "api:update": "api-extractor run --local"
  },
  "keywords": [
    "responsivevoice",
    "text-to-speech",
    "speech-synthesis",
    "tts",
    "web-speech-api",
    "voice",
    "browser",
    "streaming",
    "azure",
    "openai",
    "google-cloud",
    "typescript",
    "javascript"
  ],
  "author": "ResponsiveVoice, Inc. <support@responsivevoice.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/responsivevoice/core.git"
  },
  "bugs": {
    "url": "https://github.com/responsivevoice/core/issues"
  },
  "homepage": "https://github.com/responsivevoice/core#readme",
  "dependencies": {
    "@responsivevoice/api-client": "^2.0.0",
    "@responsivevoice/features": "^2.0.0",
    "@responsivevoice/text": "^2.0.0",
    "@responsivevoice/types": "^2.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@microsoft/api-extractor": "^7.58.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "core-js": "^3.49.0",
    "jsdom": "^29.1.1",
    "mse-audio-wrapper": "^1.4.15",
    "publint": "^0.3.21",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false,
  "pnpm": {
    "overrides": {
      "defu@<=6.1.4": ">=6.1.5",
      "yaml@>=2.0.0 <2.8.3": "^2.8.3"
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=18.12.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.2",
      "onFail": "warn"
    }
  }
}
